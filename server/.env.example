# GlucoCare server — environment variables
# Copy this file to .env and fill in real values. NEVER commit .env.

# ─── Runtime ─────────────────────────────────────────────────────────
NODE_ENV=development                 # development | test | production
PORT=5000

# ─── Firebase ────────────────────────────────────────────────────────
# In production, provide the service account JSON as a single-line string.
# In development, server/config/serviceAccountKey.json is used as fallback.
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# ─── AI (Google Gemini) ──────────────────────────────────────────────
# Required for /api/ai/* endpoints. Get from Google AI Studio.
# Without this, /api/ai/chat returns localized fallback responses.
GEMINI_API_KEY=

# ─── Payments (FlexPay — Congolese market) ───────────────────────────
PAYMENT_PROVIDER=MOCK                # MOCK | FLEXPAY | MAXICASH
# FLEXPAY_API_TOKEN=
# FLEXPAY_MERCHANT=
# FLEXPAY_MODE=development           # development | production
# FLEXPAY_WEBHOOK_SECRET=            # Required in production to verify webhook callbacks

# ─── Email (notifications + activation codes) ────────────────────────
EMAIL_PROVIDER=nodemailer            # nodemailer | sendgrid | none
GMAIL_USER=
GMAIL_APP_PASSWORD=                  # Use a Gmail app password, NOT the account password

# ─── ML Services ─────────────────────────────────────────────────────
FOOT_RISK_SERVICE_URL=

# ─── Security ────────────────────────────────────────────────────────
# Encryption key for at-rest PHI fields. Required in production. 32-byte base64.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# PHI_ENCRYPTION_KEY=

# ─── Operational ─────────────────────────────────────────────────────
# Maximum request body size (default 1mb)
# REQUEST_BODY_LIMIT=1mb

# ─── PostgreSQL (Phase 1 dual-write — additive only) ─────────────────
# RDS af-south-1 enforces TLS. The two URLs differ by DB role:
#   _PG     — app_rw, used by the running app (SELECT/INSERT/UPDATE on business
#             tables, SELECT/INSERT-only on audit_log)
#   _PG_DDL — app_ddl, used by node-pg-migrate (CI/release pipeline only)
# Leave both unset in dev to skip Postgres entirely (Firestore stays the source of truth).
# DATABASE_URL_PG=postgres://app_rw:****@<host>.<region>.rds.amazonaws.com:5432/glucosoin?sslmode=require
# DATABASE_URL_PG_DDL=postgres://app_ddl:****@<host>.<region>.rds.amazonaws.com:5432/glucosoin?sslmode=require

# Pool tuning
# PG_POOL_MAX=10                       # max connections per process
# PG_SSL=disable                       # ONLY for local Docker — never in production

# ─── Reminders (Phase 5 — Postgres-backed) ───────────────────────────
# Gates the reminderGenerationHourly + reminderDispatchEveryMinute jobs.
# Leave OFF until RDS is live and loaders are verified. When flipping to 'on',
# disable the legacy medicationReminder cron in the same deploy, or migrated
# schedules will notify twice.
# REMINDERS_PG=off
