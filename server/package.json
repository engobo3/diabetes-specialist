{
  "name": "server",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "migrate:up": "node-pg-migrate up -j sql --migrations-dir migrations --database-url-var DATABASE_URL_PG_DDL",
    "migrate:down": "node-pg-migrate down 1 -j sql --migrations-dir migrations --database-url-var DATABASE_URL_PG_DDL",
    "migrate:redo": "node-pg-migrate redo -j sql --migrations-dir migrations --database-url-var DATABASE_URL_PG_DDL",
    "migrate:status": "node-pg-migrate down 0 -j sql --migrations-dir migrations --database-url-var DATABASE_URL_PG_DDL --dry-run"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.13.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "firebase-admin": "^13.6.0",
    "firebase-functions": "^7.0.2",
    "flexpay": "^1.0.8",
    "nodemailer": "^8.0.1",
    "nodemon": "^3.1.11",
    "pdfkit": "^0.17.2",
    "pg": "^8.13.1",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": "22"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "node-pg-migrate": "^7.9.0",
    "supertest": "^7.2.2"
  }
}
